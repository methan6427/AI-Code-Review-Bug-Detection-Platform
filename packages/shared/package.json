{
  "name": "@ai-review/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts --pool threads",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs --config vitest.config.ts --pool threads",
    "test:coverage": "node ../../node_modules/vitest/vitest.mjs run --coverage --config vitest.config.ts --pool threads"
  }
}
